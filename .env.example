# --- pokemon-kafka environment (Try step) ---
# Where the pokemon-kafka repo lives (its scripts/agent.py is the environment).
POKEMON_KAFKA_DIR=../pokemon-kafka
# Path to a legally-obtained Pokemon Red ROM (.gb). Required to run real rollouts.
ROM_PATH=../pokemon-kafka/rom/pokemon_red.gb

# --- local model (Nudge #1: train) ---
# Backend: autodetected (cuda if a CUDA torch is present, else mlx). Force it here.
# AUTOTUNE_BACKEND=cuda
# Override the base model the loop trains and queries. Default is backend-aware:
#   cuda -> HuggingFaceTB/SmolLM3-3B   |   mlx -> EricFillion/smollm3-3b-mlx
# AUTOTUNE_BASE_MODEL=HuggingFaceTB/SmolLM3-3B
# CUDA: force a GPU profile instead of autodetecting from the device name (5090 | h100).
# AUTOTUNE_GPU_PROFILE=5090
# MLX: force a Mac profile instead of autodetecting from unified memory.
#   m-large (>=32GB) | m-medium (16-32GB) | m-lite (<16GB)
# AUTOTUNE_MAC_PROFILE=m-large

# --- proposer: who proposes the next genome in the Nudge step ---
#   trained (default: the SFT adapter, else heuristic) | ollama | heuristic
# Use `ollama` to run the loop end-to-end with a local model now (no trained weights,
# no base-model download) — a teacher proposer over the local Ollama API.
# AUTOTUNE_PROPOSER=ollama
# AUTOTUNE_OLLAMA_MODEL=qwen3:8b
# OLLAMA_HOST=http://localhost:11434

# --- story (Check/Reward) ---
AUTOTUNE_STORY=route1
# Final story beat by map id: 1 = Viridian City (fast demo), 2 = Pewter City (full).
AUTOTUNE_TARGET_MAP=1

# --- Nudge #2: steer the Claude param agent (optional) ---
# Only needed when running `--nudge steer`/`both` with the LLM mutation backend.
# ANTHROPIC_API_KEY=sk-ant-...

# --- storage overrides (optional) ---
# AUTOTUNE_DATA_DIR=./data
# AUTOTUNE_OUT_DIR=./out
# AUTOTUNE_LOG_DIR=./logs
